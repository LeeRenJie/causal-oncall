# Causal On-Call — environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Every variable here is read by some module in `src/causal_oncall/`.

# ----------------------------------------------------------------------
# Google Cloud — Vertex AI / Gemini
# ----------------------------------------------------------------------

# GCP project hosting the Vertex AI calls and the Cloud Run service.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region. Pick one with Gemini 3.1 Pro availability.
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model id for orchestrator + synthesizer. Day-0 spike confirmed
# `gemini-3-pro-preview` is the released preview identifier as of 2026-05.
GEMINI_MODEL_ID=gemini-3-pro-preview

# Optional: cheaper Flash model for specialist sub-agents to cut cost ~3x.
GEMINI_SPECIALIST_MODEL_ID=gemini-3-flash-preview

# Service account key path (local dev only). In Cloud Run, use Workload
# Identity instead — leave this unset there.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/local-service-account.json

# ----------------------------------------------------------------------
# Dynatrace — MCP server + tenant
# ----------------------------------------------------------------------

# Tenant base URL, e.g. https://abc12345.live.dynatrace.com
DYNATRACE_BASE_URL=https://your-tenant.live.dynatrace.com

# OAuth client credentials for the Dynatrace MCP server. Created under
# Account Management → OAuth clients. Scopes required: storage:problems:read,
# storage:events:read, storage:metrics:read, storage:entities:read,
# storage:logs:read, environment-api:problems:read.
DYNATRACE_OAUTH_CLIENT_ID=
DYNATRACE_OAUTH_CLIENT_SECRET=
DYNATRACE_OAUTH_TOKEN_URL=https://sso.dynatrace.com/sso/oauth2/token

# Optional comma-separated tool allowlist. Empty = all tools the server exposes.
# Use this to guarantee the agent cannot accidentally call destructive tools.
DYNATRACE_MCP_TOOL_ALLOWLIST=execute_dql,list_problems,get_problem_details,list_analyzers,run_changepoint_analyzer,run_forecast_analyzer,get_topology_neighbors,list_vulnerabilities

# Rate-limit pacing. Dynatrace SaaS API is 50 requests / minute / tenant.
DYNATRACE_RATE_LIMIT_PER_MINUTE=50

# ----------------------------------------------------------------------
# MongoDB Atlas — incident memory store
# ----------------------------------------------------------------------

# Standard SRV connection string from Atlas → Connect → Drivers.
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Database + collection names. M0 free tier is enough for the demo dataset.
MONGODB_DATABASE=causal_oncall
MONGODB_INCIDENTS_COLLECTION=incidents
MONGODB_VECTOR_INDEX_NAME=incident_signature_vector

# Embedding model used to vectorize problem signatures. Vertex provides
# text-embedding-005 (768 dims) which is what the Atlas index is sized for.
EMBEDDING_MODEL_ID=text-embedding-005
EMBEDDING_DIMENSIONS=768

# Pre-flight match threshold (cosine similarity 0..1). Below this we run
# the full specialist pipeline; at-or-above we short-circuit to confirmation.
MEMORY_MATCH_THRESHOLD=0.85

# ----------------------------------------------------------------------
# Slack — brief delivery + feedback loop
# ----------------------------------------------------------------------

# Bot token (xoxb-...). The bot needs chat:write and reactions:read.
SLACK_BOT_TOKEN=

# Channel id where the briefs land. Use the channel id (Cxxxx), not the name.
SLACK_BRIEF_CHANNEL_ID=

# Signing secret used to verify Slack webhooks (feedback events).
SLACK_SIGNING_SECRET=

# ----------------------------------------------------------------------
# Arize Phoenix — OSS observability SDK (not MCP)
# ----------------------------------------------------------------------

# OTLP endpoint. Local dev runs Phoenix on http://localhost:6006.
# Phoenix Cloud uses https://app.phoenix.arize.com/v1/traces.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Project name surfaced in the Phoenix UI.
PHOENIX_PROJECT_NAME=causal-oncall

# API key only required when targeting Phoenix Cloud.
PHOENIX_API_KEY=

# Local JSONL store backing the rolling top-hypothesis-accuracy metric
# read by the W3-S5 self-improvement dashboard. Cloud Run should point
# this at a mounted GCS volume so the metric survives cold starts.
PHOENIX_OUTCOME_STORE_PATH=./out/phoenix_outcomes.jsonl
